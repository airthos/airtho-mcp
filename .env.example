# Azure App Registration credentials
TENANT_ID=your-aad-tenant-id
CLIENT_ID=your-app-registration-client-id
CLIENT_SECRET=your-client-secret

# Default SharePoint site ID (from the Airtho site)
# Discover this by calling: GET https://graph.microsoft.com/v1.0/sites/airtho.sharepoint.com:/sites/Airtho
DEFAULT_SITE_ID=your-sharepoint-site-id

# Server port (Azure Container Apps injects PORT automatically)
PORT=3000

# Transport mode: 'http' (default, for Azure/remote) or 'stdio' (for local Claude Desktop/Claude Code)
TRANSPORT=http
