{
  "name": "airtho-mcp-server",
  "version": "1.0.0",
  "description": "Airtho MCP server — authenticated Microsoft Graph API access for SharePoint/OneDrive",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "npx rimraf tsconfig.tsbuildinfo",
    "build": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc && node -e \"require('fs').cpSync('src/assets','dist/assets',{recursive:true})\"",
    "watch": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --watch",
    "prestart": "npm run build",
    "start": "func start",
    "clean": "npx rimraf dist",
    "test": "jest",
    "deploy": "npm test && npm run build && func azure functionapp publish airtho-mcp --node"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@azure/functions": "^4.9.0",
    "@azure/identity": "^4.5.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.0"
  }
}
